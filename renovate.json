{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":disableDependencyDashboard"
  ],
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "bump",
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["tailwindcss"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["@astrojs/mdx"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["@astrojs/tailwind", "astro"],
      "allowedVersions": "<6"
    },
    {
      "matchPackageNames": ["@astrojs/sitemap"],
      "allowedVersions": "<=3.7.0"
    },
    {
      "matchPackageNames": ["@astrojs/rss"],
      "allowedVersions": "<=4.0.15"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": false
  }
}
